{
  "name": "@vibetech/vcs-theme",
  "version": "1.0.0",
  "description": "Vibe Code Studio design tokens — colors, typography, spacing, shadows, components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": "./dist/variables.css",
    "./tokens": "./src/tokens.ts"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "pnpm exec eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm exec vitest run --passWithNoTests --dir src"
  },
  "peerDependencies": {},
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "5.9.3"
  },
  "license": "MIT"
}
