{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/shared-config",
  "projectType": "library",
  "root": "packages/shared-config",
  "sourceRoot": "packages/shared-config/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
        "cwd": "packages/shared-config"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run",
        "cwd": "packages/shared-config"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "packages/shared-config"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint src --ext .ts,.tsx --max-warnings 0",
        "cwd": "packages/shared-config"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc --noEmit",
        "cwd": "packages/shared-config"
      }
    },
    "quality": {}
  },
  "tags": [
    "type:library",
    "scope:shared"
  ]
}
