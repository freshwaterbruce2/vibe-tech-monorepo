{
  "name": "@vibetech/shared-config",
  "version": "1.0.0",
  "description": "Shared configuration and environment utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./database-inventory": {
      "types": "./dist/database-inventory.d.ts",
      "import": "./dist/database-inventory.js",
      "default": "./dist/database-inventory.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0"
  },
  "keywords": [
    "config",
    "environment"
  ],
  "author": "VibeTech",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
