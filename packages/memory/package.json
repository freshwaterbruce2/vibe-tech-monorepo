{
  "name": "@vibetech/memory",
  "version": "1.0.0",
  "description": "Memory system with episodic, semantic, and procedural stores with vector search",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vibetech/logger": "workspace:^1.0.0",
    "better-sqlite3": "12.6.2",
    "sqlite-vec": "^0.1.7",
    "ollama": "^0.6.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@xenova/transformers": "^2.17.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
