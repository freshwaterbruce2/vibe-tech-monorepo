{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/logger",
  "projectType": "library",
  "root": "packages/logger",
  "sourceRoot": "packages/logger/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "packages/logger"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run",
        "cwd": "packages/logger"
      }
    }
  },
  "tags": ["type:library", "scope:logger"]
}
