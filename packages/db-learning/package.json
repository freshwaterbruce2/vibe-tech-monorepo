{
  "name": "@vibetech/db-learning",
  "version": "1.0.0",
  "description": "Learning database adapter with append-only writes",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate": "node dist/migrations/runner.js",
    "lint": "eslint . --max-warnings 0"
  },
  "keywords": [
    "database",
    "sqlite",
    "learning"
  ],
  "author": "VibeTech",
  "license": "MIT",
  "dependencies": {
    "@vibetech/shared-config": "workspace:^1.0.0",
    "better-sqlite3": "12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  }
}
