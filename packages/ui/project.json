{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/ui",
  "projectType": "library",
  "root": "packages/ui",
  "sourceRoot": "packages/ui/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "node ../../node_modules/eslint/bin/eslint.js src --max-warnings 0",
        "cwd": "packages/ui"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc",
        "cwd": "packages/ui"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc --noEmit",
        "cwd": "packages/ui"
      }
    },
    "quality": {}
  },
  "tags": [
    "type:library",
    "scope:ui"
  ]
}
