{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/avatars",
  "projectType": "library",
  "root": "packages/avatars",
  "sourceRoot": "packages/avatars/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
        "cwd": "packages/avatars"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint src --ext .ts,.tsx --max-warnings 0",
        "cwd": "packages/avatars"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../node_modules/typescript/bin/tsc --noEmit",
        "cwd": "packages/avatars"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "vitest run --config vitest.config.ts",
        "cwd": "packages/avatars"
      }
    },
    "quality": {}
  },
  "tags": ["type:library", "scope:shared"]
}
