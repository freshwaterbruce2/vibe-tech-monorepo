{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/types",
  "projectType": "library",
  "root": "packages/vibetech-types",
  "sourceRoot": "packages/vibetech-types/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "packages/vibetech-types"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint src --ext .ts,.tsx --max-warnings 0",
        "cwd": "packages/vibetech-types"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/vibetech-types"
      }
    },
    "quality": {}
  },
  "tags": [
    "type:library",
    "scope:vibetech"
  ]
}
