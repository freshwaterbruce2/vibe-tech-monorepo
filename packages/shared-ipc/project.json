{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/shared-ipc",
  "projectType": "library",
  "root": "packages/shared-ipc",
  "sourceRoot": "packages/shared-ipc/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "packages/shared-ipc"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint src --ext .ts,.tsx --max-warnings 0",
        "cwd": "packages/shared-ipc"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/shared-ipc"
      }
    },
    "quality": {}
  },
  "tags": [
    "type:library",
    "scope:shared"
  ]
}
