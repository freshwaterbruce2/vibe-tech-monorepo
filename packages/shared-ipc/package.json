{
  "name": "@vibetech/shared-ipc",
  "version": "1.0.0",
  "description": "IPC message schemas and contracts for NOVA-Deepcode communication",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "clean": "rimraf dist",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "keywords": [
    "ipc",
    "websocket",
    "contracts"
  ],
  "author": "VibeTech",
  "license": "MIT",
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.1.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
