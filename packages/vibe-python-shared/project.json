{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "vibe-python-shared",
  "projectType": "library",
  "root": "packages/vibe-python-shared",
  "sourceRoot": "packages/vibe-python-shared/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo 'lint not applicable: python shared package'",
        "cwd": "packages/vibe-python-shared"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo 'typecheck not applicable: python shared package'",
        "cwd": "packages/vibe-python-shared"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo 'test not applicable: python shared package'",
        "cwd": "packages/vibe-python-shared"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "command": "echo 'Python package - no build needed'",
        "cwd": "packages/vibe-python-shared"
      }
    }
  },
  "tags": ["type:library", "scope:python", "language:python"]
}
