{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@vibetech/feature-flags",
  "projectType": "library",
  "root": "packages/feature-flags",
  "sourceRoot": "packages/feature-flags/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "packages/feature-flags"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm lint",
        "cwd": "packages/feature-flags"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/feature-flags"
      }
    },
    "quality": {}
  },
  "tags": [
    "type:library",
    "scope:feature-flags"
  ]
}
