{
  "name": "@nova/core",
  "version": "2.0.0",
  "description": "NOVA Agent core business logic - intelligence and persistence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence/index.d.ts",
      "import": "./dist/intelligence/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "import": "./dist/persistence/index.js"
    },
    "./abstraction": {
      "types": "./dist/abstraction/AgentAdapter.d.ts",
      "import": "./dist/abstraction/AgentAdapter.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@nova/database": "workspace:^2.1.0",
    "@nova/types": "workspace:^2.0.0",
    "better-sqlite3": "12.6.2",
    "chokidar": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "nova",
    "agent",
    "intelligence",
    "ai"
  ],
  "author": "NOVA",
  "license": "MIT"
}
