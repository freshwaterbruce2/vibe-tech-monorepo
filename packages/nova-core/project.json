{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@nova/core",
  "projectType": "library",
  "root": "packages/nova-core",
  "sourceRoot": "packages/nova-core/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo \"No lint required\"",
        "cwd": "packages/nova-core"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo \"No typecheck required\"",
        "cwd": "packages/nova-core"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "command": "tsc",
        "cwd": "packages/nova-core"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "packages/nova-core"
      }
    }
  },
  "tags": ["type:library", "scope:nova"]
}
