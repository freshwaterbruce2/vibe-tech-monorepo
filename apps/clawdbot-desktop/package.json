    "minimatch": "^3.1.5",
    "openai": "^6.17.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.40.0",
    "screenshot-desktop": "^1.15.3",
    "systeminformation": "^5.31.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/screenshot-desktop": "^1.15.0",
    "electron": "40.1.0",
    "electron-builder": "^26.8.1",
