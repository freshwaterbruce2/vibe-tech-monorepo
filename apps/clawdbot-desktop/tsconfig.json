{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./out",
    "rootDir": "."
  },
  "include": [
    "electron/**/*.ts",
    "electron.vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
