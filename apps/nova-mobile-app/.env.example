# NOVA Mobile App — Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.

# Bearer token used by HttpAgentAdapter when calling the Nova Desktop bridge.
# Must match the token configured on the desktop side (nova-agent).
# Dev-only fallback lives in src/config.ts; production builds throw if this is unset.
EXPO_PUBLIC_BRIDGE_TOKEN=nova_default_secret_token_change_me

# Optional: override the auto-detected API host. Used for physical iOS devices
# on the same LAN as the desktop, or for pointing at a non-default port.
# Examples:
#   http://192.168.1.100:3000   # physical device on LAN
#   http://10.0.2.2:3000        # Android emulator (already the default)
#   http://localhost:3000       # iOS simulator (already the default)
# Leave unset to use platform auto-detection.
# EXPO_PUBLIC_OVERRIDE_API_URL=
