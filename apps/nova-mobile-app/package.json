{
  "name": "nova-mobile-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "adb:reverse": "pwsh ./scripts/adb-reverse.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.ts src/**/*.integration.test.ts",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.1.0",
    "@react-native-community/netinfo": "~11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "expo": "~54.0.33",
    "expo-device": "^55.0.10",
    "expo-haptics": "~55.0.9",
    "expo-local-authentication": "~55.0.9",
    "expo-notifications": "^55.0.13",
    "expo-secure-store": "~55.0.9",
    "expo-speech": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.563.0",
    "memoize-one": "^6.0.0",
    "react": "19.2.4",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "19.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "private": true
}
