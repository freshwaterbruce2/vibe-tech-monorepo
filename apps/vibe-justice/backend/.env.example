##############################
# Vibe-Justice Backend (.env)
##############################

# CRITICAL: API Key for authentication (minimum 32 characters)
# Generate secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# WARNING: Application will NOT start without this key (fail-closed security)
VIBE_JUSTICE_API_KEY=CHANGE_ME_USE_32_CHAR_MIN_abcdefghijklmnopqrstuvwxyz123456

# OpenAI API Key (required for embeddings)
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek API key (required for reasoning model)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Data directory (ChromaDB, drafts, indexed documents)
# IMPORTANT: keep on D:\ per monorepo standards
DATA_DIRECTORY=D:\VibeJusticeData

# Optional overrides used across services
DATABASE_DIR=D:\databases
LOG_DIRECTORY=D:\logs\vibe_justice

# Backend server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

