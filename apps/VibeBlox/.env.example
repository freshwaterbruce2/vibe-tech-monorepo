# Database
VIBEBLOX_DATABASE_PATH=D:\data\vibeblox\vibeblox.db

# NOTE: We intentionally avoid using the generic DATABASE_PATH because other apps
# in this monorepo set it globally. VibeBlox will only use DATABASE_PATH if it
# contains "vibeblox" in the path.
# DATABASE_PATH=D:\data\vibeblox\vibeblox.db

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change-this-to-a-secure-random-secret-key

# Server Port
PORT=3003