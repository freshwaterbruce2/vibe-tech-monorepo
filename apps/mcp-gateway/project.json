{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mcp-gateway",
  "projectType": "application",
  "root": "apps/mcp-gateway",
  "sourceRoot": "apps/mcp-gateway/src",
  "targets": {
    "dev": {
      "executor": "nx:run-script",
      "options": { "script": "dev" },
      "cache": false
    },
    "build": {
      "executor": "nx:run-script",
      "options": { "script": "build" },
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-script",
      "options": { "script": "lint" },
      "cache": true
    },
    "test": {
      "executor": "nx:run-script",
      "options": { "script": "test" },
      "cache": true
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "apps/mcp-gateway"
      }
    },
    "typecheck": {
      "executor": "nx:run-script",
      "options": { "script": "typecheck" },
      "cache": true
    }
  },
  "tags": ["scope:mcp", "type:mcp-server", "language:typescript"]
}
