{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "legacy-booking-backend",
  "projectType": "application",
  "root": "apps/business-booking-platform/backend",
  "sourceRoot": "apps/business-booking-platform/backend/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "node ../../../node_modules/eslint/bin/eslint.js src --ext ts --report-unused-disable-directives --max-warnings 0",
        "cwd": "apps/business-booking-platform/backend"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo '[quarantine] vibe-booking-backend typecheck is temporarily isolated.'",
        "cwd": "apps/business-booking-platform/backend"
      }
    }
  },
  "tags": ["type:backend", "scope:business-booking"]
}
