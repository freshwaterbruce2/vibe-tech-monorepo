# Business Booking Platform - Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
API_VERSION=1.0.0

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotelbooking
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_SIZE=20

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# JWT Secrets (generate secure random strings for production)
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_RESET_SECRET=your-reset-secret-min-32-chars

# OpenRouter AI Configuration (RECOMMENDED - Unified AI Gateway)
# Get your free API key at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat
OPENROUTER_FALLBACK_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_PREMIUM_MODEL=openai/gpt-4-turbo

# Legacy OpenAI Configuration (DEPRECATED - use OpenRouter instead)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_MAX_TOKENS=1000
# OPENAI_TEMPERATURE=0.7

# LiteAPI (Hotel Booking Service)
LITEAPI_API_KEY=your-liteapi-key
LITEAPI_BASE_URL=https://api.liteapi.travel/v1
LITEAPI_TIMEOUT=30000

# Square Payments
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_APPLICATION_ID=your-square-app-id
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-key

# Email Service
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@vibebooking.com
EMAIL_API_KEY=

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=vibebooking-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=false
