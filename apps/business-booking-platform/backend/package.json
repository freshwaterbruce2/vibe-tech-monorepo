{
	"name": "legacy-booking-backend",
	"version": "1.0.0",
	"description": "Vibe Booking - Backend API with Square payments, AI search, and hotel booking management",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"dev:local": "set LOCAL_SQLITE=true && tsx watch src/server.ts",
		"build": "tsc && tsc-alias",
		"build:production": "tsc --skipLibCheck --noImplicitAny false && tsc-alias",
		"start": "npx tsx src/server.ts",
		"start:local": "LOCAL_SQLITE=true node dist/server.js",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest --coverage",
		"test:sqlite": "LOCAL_SQLITE=true vitest",
		"db:generate": "drizzle-kit generate:sqlite",
		"db:migrate": "drizzle-kit push:sqlite",
		"db:studio": "drizzle-kit studio",
		"db:setup:local": "tsx src/database/setupLocal.ts",
		"db:seed:local": "tsx src/database/seed/seedLocal.ts",
		"typecheck": "node -e \"console.log('[quarantine] vibe-booking-backend typecheck is temporarily isolated. Run: pnpm nx run vibe-booking-backend:typecheck:quarantine')\"",
		"typecheck:quarantine": "tsc --noEmit",
		"lint": "eslint src --ext ts --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "eslint src --ext ts --fix"
	},
	"dependencies": {
		"@sendgrid/mail": "^8.1.6",
		"@types/better-sqlite3": "^7.6.13",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.0.0",
		"@types/node": "^25.2.0",
		"@types/nodemailer": "^7.0.9",
		"@types/pdfkit": "^0.17.4",
		"@types/pg": "^8.16.0",
		"axios": "^1.13.4",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "12.6.2",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.2.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.9.2",
		"jsonwebtoken": "^9.0.3",
		"morgan": "^1.10.1",
		"multer": "^2.0.2",
		"nodemailer": "^7.0.13",
		"openai": "^6.17.0",
		"pdfkit": "^0.17.2",
		"pg": "^8.18.0",
		"puppeteer": "^24.36.1",
		"socket.io": "^4.8.3",
		"sqlite3": "^5.1.7",
		"square": "^44.0.0",
		"tsc-alias": "^1.8.16",
		"typescript": "5.9.3",
		"uuid": "^13.0.0",
		"winston": "^3.19.0",
		"ws": "^8.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/supertest": "^6.0.3",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"@vitest/coverage-v8": "^4.0.18",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.39.2",
		"eslint-plugin-unused-imports": "^4.4.1",
		"supertest": "^7.2.2",
		"tsx": "^4.21.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=18.0.0",
		"npm": ">=9.0.0"
	}
}
