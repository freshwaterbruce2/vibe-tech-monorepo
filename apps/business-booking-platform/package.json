{
  "name": "business-booking-platform",
  "version": "2.0.0",
  "description": "Production-ready business hotel booking platform with AI-powered search and comprehensive features",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite --port 3009",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npx eslint src --max-warnings 0",
    "lint:fix": "npx eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx,css,md}",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:visual:update": "playwright test --config=playwright-visual.config.ts --update-snapshots",
    "analyze": "npx vite-bundle-analyzer",
    "start:payment": "node simple-payment-server.cjs",
    "turbo:build": "turbo run build",
    "turbo:test": "turbo run test:run",
    "turbo:test:e2e": "turbo run test:e2e",
    "turbo:lint": "turbo run lint",
    "turbo:typecheck": "turbo run typecheck",
    "turbo:quality": "turbo run lint typecheck test:run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.20",
    "@types/node": "^25.2.0",
    "@vibetech/hooks": "workspace:^1.0.0",
    "@vibetech/shared-utils": "workspace:^1.0.0",
    "@vibetech/ui": "workspace:^0.0.0",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.31.0",
    "lucide-react": "0.563.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "react-window": "^2.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vibetech/testing-utils": "workspace:^1.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest-axe": "^10.0.0",
    "jsdom": "28.0.0",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0",
    "npm": "Please use pnpm instead",
    "yarn": "Please use pnpm instead"
  }
}
