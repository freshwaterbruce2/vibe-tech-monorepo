{
  "name": "chessmaster-academy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run validate:lessons && pnpm run validate:chess-ai",
    "validate:lessons": "node scripts/validate-lessons.cjs",
    "validate:chess-ai": "node scripts/validate-chess-ai.cjs",
    "android:sync": "pnpm exec cap sync android",
    "android:build": "cd android && .\\gradlew.bat assembleDebug --no-daemon --console=plain",
    "android:build:clean": "cd android && .\\gradlew.bat clean assembleDebug --no-daemon --console=plain",
    "android:bundle:release": "cd android && .\\gradlew.bat bundleRelease --no-daemon --console=plain",
    "android:bundle:release:clean": "cd android && .\\gradlew.bat clean bundleRelease --no-daemon --console=plain",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:launch": "adb shell am start -n com.chess.tutor/.MainActivity",
    "android:doctor": "pnpm exec cap doctor",
    "android:full-build": "pnpm run build && pnpm exec cap sync android && pnpm run android:build:clean",
    "android:full-release": "pnpm run build && pnpm exec cap sync android && pnpm run android:bundle:release:clean",
    "api:dev": "node render-backend/server.mjs",
    "api:start": "node render-backend/server.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "chess.js": "^1.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "0.563.0",
    "motion": "^12.23.24",
    "@vibetech/games": "workspace:*",
    "react": "19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
