{
  "name": "memory-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing VibeTech memory system to Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "memory-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
