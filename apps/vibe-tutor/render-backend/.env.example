# Vibe-Tutor backend environment variables (example)
# Copy to `.env` for local dev, or set these in Render/Railway/Heroku dashboard.

# Google Gemini API (PRIMARY provider for production)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# OpenRouter API (FALLBACK provider)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# Server Port
PORT=3001
