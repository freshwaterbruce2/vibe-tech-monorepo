{
  "name": "vibe-tutor",
  "private": true,
  "version": "1.5.9",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "electron:ensure-cjs": "node scripts/ensure-electron-cjs.cjs",
    "electron:watch": "tsc -p tsconfig.electron.json -w",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:start": "pnpm run electron:ensure-cjs && wait-on tcp:5173 dist-electron/main.js dist-electron/preload.js && cross-env NODE_ENV=development electron dist-electron/main.js",
    "dev:electron": "tsc -p tsconfig.electron.json -w",
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && pnpm run dev:electron\"",
    "dev:app": "concurrently -k -n dev,electron \"pnpm:dev\" \"pnpm:electron:start\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "pnpm run build && pnpm run build:electron && electron-builder",
    "typecheck": "pnpm exec tsc -p tsconfig.app.json --noEmit",
    "build": "pnpm run typecheck && vite build",
    "build:desktop": "pnpm run typecheck && vite build && pnpm run electron:build && pnpm run electron:ensure-cjs && electron-builder --win",
    "preview": "vite preview",
    "start": "node server/server.mjs",
    "test:unit": "vitest",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:jamendo": "tsx tests/test-jamendo.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "android:sync": "pnpm exec cap sync android",
    "android:build": "cd android && .\\gradlew.bat assembleDebug",
    "android:build:clean": "cd android && .\\gradlew.bat clean assembleDebug",
    "android:bundle:release": "cd android && .\\gradlew.bat bundleRelease",
    "android:bundle:release:clean": "cd android && .\\gradlew.bat clean bundleRelease",
    "android:open": "pnpm exec cap open android",
    "android:doctor": "pnpm exec cap doctor",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "android:uninstall": "adb uninstall com.vibetech.tutor || exit 0",
    "android:logs": "adb logcat | findstr /I capacitor",
    "android:full-build": "pnpm run build && pnpm exec cap sync android && cd android && .\\gradlew.bat clean assembleDebug",
    "android:full-release": "pnpm run build && pnpm exec cap sync android && pnpm run android:bundle:release:clean",
    "android:deploy": "pnpm run android:full-build && pnpm run android:uninstall && pnpm run android:install"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@capacitor/file-transfer": "^2.0.3",
    "@capacitor/filesystem": "^8.1.0",
    "@google/genai": "^1.39.0",
    "@jaredreisinger/react-crossword": "^5.2.0",
    "@mediagrid/capacitor-native-audio": "^3.0.0",
    "@react-spring/web": "^10.0.3",
    "@sentry/react": "^10.38.0",
    "@vibetech/openrouter-client": "workspace:^1.0.0",
    "better-sqlite3": "12.6.2",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "howler": "^2.2.4",
    "jeep-sqlite": "^2.8.0",
    "lucide-react": "0.563.0",
    "music-metadata": "^11.11.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sudoku-umd": "^1.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.2.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-istanbul": "^4.0.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "40.1.0",
    "electron-builder": "^26.7.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.vibetech.vibetutor",
    "productName": "Vibe Tutor",
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
