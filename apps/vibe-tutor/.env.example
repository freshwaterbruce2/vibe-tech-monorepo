# Vibe-Tutor Environment Variables
# Updated: February 26, 2026

# ============== BACKEND SERVER SECRETS ==============
# These keys should ONLY be set on the backend server, never in the client.

# Google Gemini (PRIMARY AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (FALLBACK AI provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Server Port (optional, defaults to 3001)
PORT=3001

# Environment Mode
NODE_ENV=production

# Optional: Additional CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com

# Optional: Analytics log directory (default: ./logs)
# ANALYTICS_LOG_DIR=/path/to/logs

# SECURITY NOTES:
# 1. NEVER commit the actual .env file to version control
# 2. Keep API keys on the backend server only
# 3. The client app connects to the backend via secure proxy
# 4. All API calls are authenticated with session tokens
# 5. For production: set these as env vars on your hosting platform (Cloud Run, Render, etc.)
