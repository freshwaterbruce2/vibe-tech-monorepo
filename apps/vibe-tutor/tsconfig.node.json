{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": [
    "vite.config.ts", 
    "vitest.config.ts",
    "capacitor.config.ts",
    "playwright.config.ts",
    "postcss.config.js"
  ]
}
