{
  "name": "vibe-tech-backend",
  "version": "1.0.0",
  "description": "Backend server for Vibe Tech with local SQLite database",
  "main": "server.js",
  "scripts": {
    "build": "node -e \"console.log('build not applicable: runtime JavaScript service')\"",
    "start": "node server-production.js",
    "dev": "nodemon server.js",
    "dev:prod": "set NODE_ENV=production && nodemon server-production.js",
    "dev:prod:unix": "NODE_ENV=production nodemon server-production.js",
    "prod": "set NODE_ENV=production && node server-production.js",
    "prod:unix": "NODE_ENV=production node server-production.js",
    "lint": "eslint server.js server-production.js middleware --max-warnings 0",
    "typecheck": "node -e \"console.log('typecheck not applicable: JavaScript service')\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "health": "curl -f http://localhost:3000/health || exit 1"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "sqlite3": "^5.1.7",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
