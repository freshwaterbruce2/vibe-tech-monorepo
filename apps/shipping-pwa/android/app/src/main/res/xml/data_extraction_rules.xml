<?xml version="1.0" encoding="utf-8"?>
<!-- Data extraction rules for DC8980 Shipping App (Android 12+) -->
<!-- Controls what data can be extracted during device-to-device transfer -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include user preferences for cloud backup -->
        <include domain="sharedpref" path="user_settings.xml"/>

        <!-- Exclude sensitive operational data from cloud backup -->
        <exclude domain="database" path="."/>
        <exclude domain="file" path="exports/"/>
        <exclude domain="file" path="operational_data/"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include essential user data for device transfer -->
        <include domain="sharedpref" path="user_settings.xml"/>
        <include domain="database" path="app_data.db"/>

        <!-- Exclude temporary and cache data -->
        <exclude domain="file" path="cache/"/>
        <exclude domain="file" path="temp/"/>
        <exclude domain="file" path="voice_temp/"/>
        <exclude domain="file" path="logs/"/>

        <!-- Exclude device-specific configurations -->
        <exclude domain="sharedpref" path="device_specific.xml"/>
    </device-transfer>
</data-extraction-rules>