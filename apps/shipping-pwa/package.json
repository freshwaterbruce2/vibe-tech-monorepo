{
	"name": "shipping-pwa",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build && node scripts/pwa-build-optimizer.js",
		"build:mobile": "vite build && node scripts/pwa-build-optimizer.js && npx cap sync",
		"build:worker": "wrangler deploy --dry-run --outdir dist-worker",
		"build:pwa": "vite build && node scripts/pwa-build-optimizer.js --optimizeImages true --generateWebP true --generateAVIF true",
		"build:analyze": "vite build --mode analyze && node scripts/pwa-build-optimizer.js",
		"lint": "npx eslint . --max-warnings 750",
		"preview": "vite preview",
		"test": "vitest",
		"test:run": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:ui": "vitest --ui",
		"server": "tsx server/index.ts",
		"server:dev": "tsx watch server/index.ts",
		"lighthouse": "node lighthouse.js",
		"pwa:audit": "node scripts/pwa-audit.js",
		"pwa:optimize": "node scripts/pwa-build-optimizer.js",
		"typecheck": "tsc --noEmit",
		"prepare": "node -e \"console.log('husky prepare skipped for shipping-pwa install')\"",
		"cap:sync": "npx cap sync",
		"cap:open:android": "npx cap open android",
		"cap:open:ios": "npx cap open ios",
		"cap:run:android": "npx cap run android",
		"cap:run:ios": "npx cap run ios",
		"android:build": "npm run build:mobile && cd android && ./gradlew assembleRelease",
		"android:bundle": "npm run build:mobile && cd android && ./gradlew bundleRelease",
		"android:upload": "npm run android:bundle && npx @capacitor/cli deploy android --upload-keystore",
		"ios:build": "npm run build:mobile && npx cap open ios",
		"ios:archive": "npm run build:mobile && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -archivePath ios/App/build/App.xcarchive archive",
		"deploy:android": "npm run quality && npm run android:bundle",
		"deploy:ios": "npm run quality && npm run ios:build",
		"quality": "npm run lint && npm run build",
		"worker:dev": "wrangler dev",
		"worker:deploy": "wrangler deploy",
		"worker:deploy:staging": "wrangler deploy --env staging",
		"worker:deploy:production": "wrangler deploy --env production",
		"db:create": "wrangler d1 create dc8980-shipping-db",
		"db:migrate": "wrangler d1 migrations apply dc8980-shipping-db",
		"db:migrate:local": "wrangler d1 migrations apply dc8980-shipping-db --local",
		"pages:deploy": "npm run build && wrangler pages deploy dist"
	},
	"dependencies": {
		"@capacitor/android": "^8.3.0",
		"@capacitor/cli": "^8.3.0",
		"@capacitor/core": "^8.3.0",
		"@capacitor/ios": "^8.3.0",
		"@radix-ui/react-accordion": "^1.2.12",
