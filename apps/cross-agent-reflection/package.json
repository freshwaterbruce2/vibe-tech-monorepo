{
  "name": "cross-agent-reflection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:client": "vite --port 5185",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint src server --ext .ts,.tsx"
  },
  "dependencies": {
    "openai": "^4.100.0",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.31",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react-swc": "^3.9.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
