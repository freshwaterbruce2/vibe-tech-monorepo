# Production Environment Variables
# Copy this to your server environment (.env) or service configuration

# Stripe Production Keys
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Local Database (MUST be on D:\)
DATABASE_PATH=D:\\databases\\invoiceflow.db

# Local Auth (MUST be set; >= 32 chars)
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Server
HOST=0.0.0.0
PORT=8787
TRUST_PROXY=1
SERVE_WEB=1
WEB_DIST_DIR=C:\\dev\\apps\\invoice-automation-saas\\dist

# Cookies (for domain deployments)
COOKIE_DOMAIN=invoiceflow.yourdomain.com
SESSION_TTL_SECONDS=604800

# Sentry Production
VITE_SENTRY_DSN=https://your-production-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production

# Analytics
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-production-mixpanel-token

# Application
VITE_APP_URL=https://invoiceflow.com
NODE_ENV=production

# Feature Flags
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=true
