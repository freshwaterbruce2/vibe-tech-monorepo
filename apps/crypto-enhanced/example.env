# Example environment file for crypto-enhanced
# Copy to .env and fill with real values. Do NOT commit secrets.

# Primary Kraken API credentials (required)
KRAKEN_API_KEY=REPLACE_WITH_PRIMARY_KEY
KRAKEN_API_SECRET=REPLACE_WITH_PRIMARY_SECRET_BASE64

# Secondary/tertiary keys (optional, for nonce isolation)
KRAKEN_API_KEY_2=
KRAKEN_API_SECRET_2=
KRAKEN_API_KEY_3=
KRAKEN_API_SECRET_3=

# WebSocket token (optional if using WS private channels)
KRAKEN_WS_TOKEN=

# Nonce window (keep high for reliability)
KRAKEN_NONCE_WINDOW=10000

# Paths and logging
DB_PATH=trading.db
LOG_LEVEL=INFO
BASE_CURRENCY=USD

# Risk limits (match trading_config.json defaults)
MAX_POSITION_SIZE=10
MAX_TOTAL_EXPOSURE=10
MAX_POSITIONS=1
MIN_BALANCE_REQUIRED=15
MIN_BALANCE_ALERT=50

# WebSocket settings
WS_RECONNECT_INTERVAL=5
WS_HEARTBEAT_INTERVAL=30

# Order settings
DEFAULT_ORDER_TYPE=limit
SLIPPAGE_TOLERANCE=0.001

# Monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL=60
