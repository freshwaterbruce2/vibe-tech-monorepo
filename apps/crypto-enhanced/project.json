{
	"name": "crypto-enhanced",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": ".",
	"projectType": "application",
	"tags": ["scope:trading", "type:service", "language:python"],
	"targets": {
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"command": "echo 'lint not applicable: python trading app'",
				"cwd": "apps/crypto-enhanced"
			}
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "echo 'typecheck not applicable: python trading app'",
				"cwd": "apps/crypto-enhanced"
			}
		},
		"install": {
			"executor": "nx:run-commands",
			"options": {
				"command": "python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
				"cwd": "apps/crypto-enhanced"
			}
		},
		"start": {
			"executor": "nx:run-commands",
			"options": {
				"command": ".venv\\Scripts\\python.exe start_live_trading.py",
				"cwd": "apps/crypto-enhanced"
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": ".venv\\Scripts\\python.exe run_tests.py",
				"cwd": "apps/crypto-enhanced"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"outputs": ["{projectRoot}/dist"],
			"cache": true,
			"options": {
				"command": "echo 'build not applicable: python trading app'",
				"cwd": "apps/crypto-enhanced"
			}
		}
	}
}
