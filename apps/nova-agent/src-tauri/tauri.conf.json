{
  "productName": "NOVA Agent",
  "version": "1.3.0",
  "identifier": "com.nova.agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:frontend"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "2025 NOVA Team",
    "shortDescription": "Neural Omnipresent Virtual Assistant",
    "longDescription": "A personalized AI agent with memory and project management capabilities",
    "resources": [],
    "icon": ["icons/icon.ico"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"]
      },
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "hardenedRuntime": true
    }
  },
  "app": {
    "security": {
      "csp": {
        "default-src": "'self' data:",
        "img-src": "'self' data: https: asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:3001 http://localhost:3100 http://localhost:3200 http://localhost:5187 http://localhost:8000 http://localhost:8001 http://localhost:9001 http://localhost:11434 https://openrouter.ai https://api.moonshot.ai https://api.deepseek.com https://api.groq.com",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:"
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "NOVA Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "macOSPrivateApi": false,
    "withGlobalTauri": false
  }
}
