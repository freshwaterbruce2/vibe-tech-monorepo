{
  "name": "nova-agent",
  "version": "1.3.0",
  "description": "Neural Omnipresent Virtual Assistant - A personalized AI agent with memory and project management",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tauri dev",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "vite",
    "inngest:serve": "tsx src/rag/inngest-serve.ts",
    "inngest:dev": "concurrently \"tsx src/rag/inngest-serve.ts\" \"npx inngest-cli@latest dev -u http://localhost:3100/api/inngest\"",
    "build": "tauri build",
    "build:frontend": "vite build",
    "build:web": "pnpm run build:frontend",
    "start": "tauri dev",
    "cli": "tsx src/cli.ts",
    "tauri": "tauri",
    "build:watch": "tsc -w",
    "clean": "rimraf dist node_modules/.cache .nyc_output coverage",
    "clean:all": "pnpm run clean && rimraf node_modules",
    "setup:cross-platform": "pnpm install && pnpm run build",
    "test": "vitest run",
    "test:web": "vitest --config vitest.browser.config.ts",
    "test:all": "pnpm run test && pnpm run test:web",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:integration": "vitest run src/tests",
    "test:performance": "vitest run --reporter=json --outputFile=performance-results.json",
    "test:wsl": "vitest --pool=forks --poolOptions.forks.singleFork=true",
    "test:wsl:watch": "vitest watch --pool=forks --poolOptions.forks.singleFork=true",
    "test:wsl:coverage": "vitest run --coverage --pool=forks --poolOptions.forks.singleFork=true",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ignore-pattern \"src/**/*.test.ts\" --ignore-pattern \"src/**/*.test.tsx\" --ignore-pattern \"src/**/__tests__/**\" --ignore-pattern \"src/test/**\" --ignore-pattern \"src/tests/**\"",
    "lint:fix": "pnpm run lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "benchmark": "node scripts/performance-benchmark.js",
    "memory-check": "node --expose-gc scripts/memory-leak-detector.js",
    "deps:check": "pnpm outdated && pnpm audit",
    "deps:update": "npx npm-check-updates -u --target minor && pnpm install",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "complexity": "npx code-complexity src --format json",
    "duplicates": "npx jscpd src --reporters json",
    "setup:hooks": "node -e \"console.log('No project-local husky hooks to install.')\"",
    "automation:status": "echo '🤖 Nova Agent Automation System v1.0.0 - Ready!'",
    "quality:check": "pnpm run build && pnpm run test:wsl -- --run",
    "quality:fix": "pnpm run lint:fix && pnpm run typecheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps"
  },
  "bin": {
    "nova": "./dist/cli.js"
  },
  "keywords": [
    "ai",
    "agent",
    "assistant",
    "deepseek",
    "memory",
    "rag"
  ],
  "author": "NOVA",
  "license": "MIT",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.1",
    "@nova/core": "workspace:^2.0.0",
    "@nova/types": "workspace:^2.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.95.2",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@vibetech/inngest-client": "workspace:*",
    "@vibetech/openrouter-client": "workspace:^1.0.0",
    "@vibetech/shared-ipc": "workspace:^1.0.0",
    "@vibetech/shared-utils": "workspace:^1.0.0",
    "@vibetech/ui": "workspace:^0.0.0",
    "better-sqlite3": "12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "0.577.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.6",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^27.0.2",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-win32-x64-msvc": "4.59.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "code-complexity": "^4.4.4",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "28.1.0",
    "lint-staged": "^16.4.0",
    "lovable-tagger": "^1.1.13",
    "madge": "^8.0.0",
    "npm-check-updates": "^19.6.6",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "snyk": "^1.1303.2",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "tailwindcss": "4.2.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0",
    "wait-on": "^9.0.4"
  }
}
