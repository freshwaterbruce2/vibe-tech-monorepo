# AVGE Dashboard — Environment Variables
# Copy to .env and fill in your API keys.
# All keys are optional — modules fall back to stubs when missing.

# ─── NotebookLM ───
# Auth is handled via `notebooklm-mcp-auth` (browser OAuth).
# No API key needed here — MCP bridge routes to the MCP server.

# ─── Google Cloud Text-to-Speech ───
# Free tier: 4M chars/month (standard), 1M chars/month (Neural2/WaveNet)
# Get key: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLOUD_TTS_KEY=

# ─── Flux Schnell (Image Generation) ───
# Free tier: 10 req/min via fal.ai
# Get key: https://fal.ai/dashboard/keys
VITE_FLUX_API_KEY=

# ─── Optional: Custom Flux endpoint ───
# Default: https://fal.run/fal-ai/flux/schnell
# VITE_FLUX_ENDPOINT=
