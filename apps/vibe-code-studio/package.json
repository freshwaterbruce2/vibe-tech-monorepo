{
	"name": "vibe-code-studio",
	"version": "1.2.0",
	"type": "module",
	"description": "Vibe Code Studio - Next-generation AI-powered code editor where innovation meets elegant design",
	"keywords": [
		"code editor",
		"AI assistant",
		"programming",
		"IDE",
		"cursor alternative",
		"monaco editor",
		"vibe code studio"
	],
	"homepage": "https://vibecodestudio.dev",
	"license": "MIT",
	"author": "Fresh Bruce",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"build:production": "pnpm run build",
		"build:analyze": "cross-env ANALYZE=true NODE_OPTIONS=\"--max-old-space-size=8192\" vite build",
		"dev:web": "vite --port 3001",
		"backend": "pnpm run tauri:dev",
		"package": "pnpm run tauri:build",
		"release:build": "pnpm run build",
		"release:build:win": "pnpm run tauri:build",
		"release:build:mac": "pnpm run tauri:build",
		"release:build:linux": "pnpm run tauri:build",
		"release:dist": "pnpm run build",
		"prepare-native-modules": "node -e \"console.log('No native module preparation required for current local setup.')\"",
		"format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
		"hook:memory": "node hooks/memory-monitor.js",
		"hook:performance": "node hooks/performance-monitor.js",
		"hook:pre-commit": "node hooks/pre-commit.js",
		"lint":"cd ../.. && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" pnpm exec eslint apps/vibe-code-studio/src --max-warnings 0",
		"lint:fix": "cd ../.. && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" pnpm exec eslint apps/vibe-code-studio/src --fix",
		"preview": "vite preview",
		"setup:hooks":"node scripts/setup-hooks.js",
		"test": "node ../../node_modules/vitest/vitest.mjs run",
		"test:e2e": "tsx tests/run-e2e-tests.ts",
		"test:e2e:headed": "HEADLESS=false tsx tests/run-e2e-tests.ts",
		"test:verify": "tsx tests/auto-verify.ts",
		"test:all": "pnpm test && pnpm test:e2e",
		"typecheck": "tsc --noEmit",
		"typecheck:strict": "tsc --noEmit",
		"typecheck:all": "pnpm run typecheck && pnpm run typecheck:build && pnpm run typecheck:test",
		"typecheck:build": "tsc --noEmit -p tsconfig.build.json",
		"typecheck:test": "tsc --noEmit -p tsconfig.test.json",
		"typecheck:watch": "tsc --noEmit --watch",
		"rebuild-deps": "node -e \"console.log('No native dependency rebuild required for current local setup.')\"",
		"tauri:dev": "node ./scripts/run-tauri.cjs dev",
		"tauri:build": "node ./scripts/run-tauri.cjs build",
		"tauri:build:debug": "node ./scripts/run-tauri.cjs build --debug"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tauri-apps/cli": "^2.10.1",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/glob": "^8.1.0",
		"@types/js-yaml": "^4.0.9",
		"@types/react": "19.2.10",
		"@types/react-dom": "19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitejs/plugin-react": "^5.2.0",
		"buffer": "^6.0.3",
		"chokidar": "^5.0.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"husky": "^9.1.7",
		"jsdom": "^28.0.0",
		"lint-staged": "^16.4.0",
		"monaco-editor": "^0.55.1",
		"prettier": "^3.8.1",

		"rollup-plugin-visualizer": "^6.0.11",
		"sort-package-json": "^3.6.1",
		"stream-browserify": "^3.0.0",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1",
		"vite-bundle-analyzer": "^1.3.6",
		"vite-node": "5.3.0",
		"vite-plugin-compression": "^0.5.1",
		"vitest": "^4.1.2",
		"wait-on": "^9.0.4",
		"webpack-bundle-analyzer": "^5.3.0"
	},
	"dependencies": {
"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@modelcontextprotocol/sdk": "^1.27.0",
		"@monaco-editor/react": "^4.7.0",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-dialog": "^2",
		"@tauri-apps/plugin-fs": "^2",
		"@tauri-apps/plugin-os": "^2.3.2",
		"@tauri-apps/plugin-shell": "^2",
		"@tauri-apps/plugin-store": "^2",
		"@vibetech/feature-flags-sdk-node": "workspace:^0.1.0",
		"@vibetech/shared-ipc": "workspace:^1.0.0",
		"@vibetech/shared-utils": "workspace:^1.0.0",
		"@vibetech/types": "workspace:^1.0.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"axios": "^1.13.6",
		"crypto-js": "^4.2.0",
		"d3": "^7.9.0",
		"diff-match-patch": "^1.0.5",
		"eventsource-parser": "^3.0.6",
		"framer-motion": "^12.38.0",
		"immer": "^11.1.4",
		"isomorphic-dompurify": "^2.36.0",
		"js-yaml": "^4.1.1",
		"lucide-react": "0.563.0",
		"marked": "^17.0.5",
		"minimatch": "^10.2.4",
		"monacopilot": "^1.2.12",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-error-boundary": "^6.1.1",
		"react-force-graph": "^1.48.2",
		"react-hotkeys-hook": "^5.2.4",
		"react-router-dom": "^7.1.0",
		"react-syntax-highlighter": "^16.1.1",
		"react-virtualized-auto-sizer": "^2.0.3",
		"react-window": "^2.2.7",
		"styled-components": "^6.3.12",
		"uuid": "^13.0.0",
		"y-monaco": "^0.1.6",
		"y-websocket": "^3.0.0",
		"yjs": "^13.6.30",
		"zod": "4.3.6",
		"zustand": "^5.0.11"
	}
}
