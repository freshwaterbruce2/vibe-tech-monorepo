{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "vibe-shop",
  "projectType": "application",
  "sourceRoot": "apps/vibe-shop/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev",
        "cwd": "apps/vibe-shop"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/.next"
      ],
      "options": {
        "command": "pnpm run build",
        "cwd": "apps/vibe-shop",
        "env": {
          "NODE_ENV": "production"
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "pnpm run start",
        "cwd": "apps/vibe-shop"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint apps/vibe-shop/src",
        "cwd": "."
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma migrate dev",
        "cwd": "apps/vibe-shop"
      }
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma generate",
        "cwd": "apps/vibe-shop"
      }
    },
    "db:studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma studio",
        "cwd": "apps/vibe-shop"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/vibe-shop"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run test",
        "cwd": "apps/vibe-shop"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "pnpm run test:coverage",
        "cwd": "apps/vibe-shop"
      }
    },
    "quality": {}
  },
  "tags": [
    "scope:app",
    "type:web",
    "stack:nextjs",
    "stack:prisma"
  ]
}
