{
  "name": "workspace-mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server for VibeTech workspace config: API keys, ports, servers, plugins, databases, env vars",
  "scripts": {
    "build": "tsc -p tsconfig.json --incremental false",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@vibetech/shared-config": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "dotenv": "^16.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "5.9.3"
  }
}
