# ========================================
# Gemini Code Assist Context Exclusions
# ========================================
# Files and directories excluded from Gemini's context window
# to optimize performance and relevance.

# ========================================
# Dependencies (massive, low context value)
# ========================================
node_modules/
**/node_modules/
.pnpm-store/
.pnpm/
bower_components/
jspm_packages/
package-lock.json
pnpm-lock.yaml
yarn.lock
bun.lock
bun.lockb

# ========================================
# Build Outputs & Generated Code
# ========================================
dist/
**/dist/
build/
**/build/
.next/
**/.next/
.nuxt/
.output/
out/
.nx/
target/
**/target/
.turbo/
.angular/
storybook-static/
generated/

# ========================================
# Test Artifacts
# ========================================
coverage/
**/coverage/
test-results/
playwright-report/
.nyc_output/
junit-reports/
cypress/videos/
cypress/screenshots/

# ========================================
# Cache Directories
# ========================================
cache/
.cache/
**/.cache/
.vite/
**/.vite/
*.tsbuildinfo
.eslintcache
.prettiercache
.stylelintcache
.sass-cache/

# ========================================
# AI Agent Data & Logs
# ========================================
.gemini/tmp/
.claude/logs/
.claude/context/
.serena/
.agent/data/
.antigravity/cache/
notebooklm/
logs/
**/logs/
*.log
*.log.*

# ========================================
# D:\ Drive Data Storage (Windows)
# ========================================
# Explicit excludes in case of symlinks or mishandling
D:/databases/
D:/logs/
D:/temp/
D:/backups/
D:/data/
D:/screenshots/
D:/build-cache/
D:/pnpm-store/
D:/learning-system/

