    "nx-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": ["nx", "mcp"]
    },
    "sqlite": {
      "transport": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\fresh_zxae3v6\\AppData\\Roaming\\npm\\node_modules\\mcp-server-sqlite-npx\\dist\\index.js",
        "D:\\databases\\database.db"
      ]
    },
    "sqlite-trading": {
      "transport": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\fresh_zxae3v6\\AppData\\Roaming\\npm\\node_modules\\mcp-server-sqlite-npx\\dist\\index.js",
        "D:\\databases\\crypto-enhanced\\trading.db"
      ]
    },
    "contextstream": {
      "transport": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@contextstream/mcp-server"],
