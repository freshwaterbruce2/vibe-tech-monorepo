{
  "context": {
    "fileName": ".gemini/rules-global.md"
  },
  "mcpServers": {
    "filesystem": {
      "transport": "stdio",
      "command": "node",
      "args": [
        "C:\\Users\\fresh_zxae3v6\\AppData\\Roaming\\npm\\node_modules\\@modelcontextprotocol\\server-filesystem\\dist\\index.js",
        "C:\\dev",
        "D:\\databases",
        "D:\\logs",
        "D:\\learning-system"
      ]
