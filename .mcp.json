{
  "mcpServers": {
    "desktop-commander": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/desktop-commander-v3/dist/mcp.js"],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/dev",
        "D:/databases",
        "D:/logs",
        "D:/learning-system",
        "D:/data"
      ]
    },
    "nx-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx.cmd", "-y", "nx-mcp@latest"],
      "env": {
        "NX_WORKSPACE_ROOT": "C:/dev"
      }
    },
    "sqlite": {
      "type": "stdio",
      "command": "C:/Users/fresh_zxae3v6/.local/bin/uvx.exe",
      "args": ["mcp-server-sqlite", "--db-path", "D:/databases/database.db"]
    },
    "skills": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/mcp-skills-server/dist/index.js"]
    },
    "memory": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/memory-mcp/dist/index.js"],
      "env": {
        "MEMORY_DB_PATH": "D:/databases/memory.db",
        "MEMORY_EMBEDDING_MODEL": "text-embedding-3-small",
        "MEMORY_EMBEDDING_DIM": "1536",
        "MEMORY_EMBEDDING_ENDPOINT": "http://localhost:3001",
        "LEARNING_DB_PATH": "D:/databases/agent_learning.db"
      }
    },
    "youtube": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@anaisbetts/mcp-youtube"]
    },
    "notebooklm": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "notebooklm_mcp_server"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "env": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1"
      }
    },
    "rag": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/mcp-rag-server/dist/index.js"],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "workspace": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/workspace-mcp-server/dist/index.js"],
      "env": {
        "WORKSPACE_ROOT": "C:/dev"
      }
    },
    "command-center": {
      "type": "stdio",
      "command": "node.exe",
      "args": ["C:/dev/apps/vibetech-command-center/dist/mcp/server.js"],
      "env": {
        "NODE_ENV": "production"
      }
    }
  }
}
