{
  "name": "@vibetech/agent-sdk-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Autonomous AI agents using the Anthropic Agent SDK for code review, quality gates, and workspace operations",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "code-reviewer": "tsx src/agents/code-reviewer.ts",
    "quality-gate": "tsx src/agents/quality-gate.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
