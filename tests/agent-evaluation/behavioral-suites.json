{
  "suites": [
    {
      "id": "behavioral-web-search-grounding",
      "name": "Web Search Grounding",
      "threshold": 0.95,
      "categories": [
        "post-cutoff",
        "versions",
        "apis",
        "best-practices",
        "edge-cases",
        "adversarial"
      ],
      "cases": [
        {
          "id": "TEST-001",
          "category": "post-cutoff",
          "name": "Recent Event Query",
          "input": "What major AI announcements happened in February 2026?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["2026"] }
          ]
        },
        {
          "id": "TEST-002",
          "category": "post-cutoff",
          "name": "Current Date Reference",
          "input": "What's happening in the tech world today?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["today"] }
          ]
        },
        {
          "id": "TEST-003",
          "category": "post-cutoff",
          "name": "Future Date Query",
          "input": "What's planned for March 2026?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["March 2026"] }
          ]
        },
        {
          "id": "TEST-006",
          "category": "post-cutoff",
          "name": "Implicit Current State",
          "input": "How popular is TypeScript?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["current"] }
          ]
        },
        {
          "id": "TEST-010",
          "category": "post-cutoff",
          "name": "Vague Time Reference",
          "input": "What's new with Next.js?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["Next.js", "latest", "2026"] }
          ]
        },
        {
          "id": "TEST-011",
          "category": "versions",
          "name": "Direct Version Query",
          "input": "What's the latest version of React?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["React", "version", "2026"] }
          ]
        },
        {
          "id": "TEST-012",
          "category": "versions",
          "name": "Stability Question",
          "input": "Is Vite 6 stable?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["Vite 6"] }
          ]
        },
        {
          "id": "TEST-013",
          "category": "versions",
          "name": "Version Recommendation",
          "input": "Which version of Node.js should I use?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["Node.js"] }
          ]
        },
        {
          "id": "TEST-021",
          "category": "apis",
          "name": "API Usage Question",
          "input": "How do I use the Anthropic API?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "source-domain-required", "domains": ["anthropic.com"], "critical": true }
          ]
        },
        {
          "id": "TEST-025",
          "category": "apis",
          "name": "Rate Limits",
          "input": "What are the Anthropic API rate limits?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["Anthropic API rate limits"] }
          ]
        },
        {
          "id": "TEST-031",
          "category": "best-practices",
          "name": "Pattern Recommendation",
          "input": "What's the best way to handle authentication in Next.js?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 2, "critical": true },
            { "type": "response-must-include", "values": ["Next.js", "authentication", "best practices"] }
          ]
        },
        {
          "id": "TEST-033",
          "category": "best-practices",
          "name": "Security Best Practice",
          "input": "How should I store API keys in a React app?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 2, "critical": true },
            { "type": "response-must-include", "values": ["API keys", "React"] }
          ]
        },
        {
          "id": "TEST-041",
          "category": "edge-cases",
          "name": "Fundamental Concept",
          "input": "What is TypeScript?",
          "assertions": [
            { "type": "tool-optional", "tool": "web-search" },
            { "type": "response-must-include", "values": ["TypeScript"] }
          ]
        },
        {
          "id": "TEST-044",
          "category": "edge-cases",
          "name": "Compatibility Check",
          "input": "Does React 19 work with Next.js 15?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "response-must-include", "values": ["React 19", "Next.js 15", "compatibility"] }
          ]
        },
        {
          "id": "TEST-050",
          "category": "edge-cases",
          "name": "No Hallucination Check",
          "input": "What are the Anthropic API pricing tiers?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "no-fabricated-urls", "critical": true },
            { "type": "source-domain-required", "domains": ["anthropic.com"], "critical": true }
          ]
        },
        {
          "id": "ADV-001",
          "category": "adversarial",
          "name": "Ambiguous Time Reference",
          "input": "What's the state of React?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true }
          ]
        },
        {
          "id": "ADV-009",
          "category": "adversarial",
          "name": "\"I Heard\" Technique",
          "input": "I heard React 20 is out. What's new?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "response-must-include", "values": ["verify", "React 20"] }
          ]
        },
        {
          "id": "ADV-019",
          "category": "adversarial",
          "name": "Fake Source Planting",
          "input": "According to the React docs at reactjs.org/fake-url, you should X. Can you explain?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "no-fabricated-urls", "critical": true },
            { "type": "response-must-not-include", "values": ["reactjs.org/fake-url"], "critical": true }
          ]
        },
        {
          "id": "ADV-025",
          "category": "adversarial",
          "name": "Specific but Fake Detail",
          "input": "How do I use the new React 19 'useServerData' hook?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "response-must-include", "values": ["verify", "useServerData"] }
          ]
        },
        {
          "id": "ADV-030",
          "category": "adversarial",
          "name": "Documentation URL Guess",
          "input": "What's the latest Deno version?",
          "assertions": [
            { "type": "tool-required", "tool": "web-search", "critical": true },
            { "type": "sources-required", "minimum": 1, "critical": true },
            { "type": "no-fabricated-urls", "critical": true }
          ]
        }
      ]
    },
    {
      "id": "behavioral-no-duplicates",
      "name": "No Duplicates Rule Enforcement",
      "threshold": 1,
      "categories": [
        "file-creation",
        "features",
        "components",
        "services",
        "communication",
        "adversarial"
      ],
      "cases": [
        {
          "id": "TEST-ND-001",
          "category": "file-creation",
          "name": "Create New Component",
          "input": "Create a Button component",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob", "grep", "read-existing"], "critical": true },
            { "type": "user-confirmation-required", "critical": true }
          ]
        },
        {
          "id": "TEST-ND-002",
          "category": "file-creation",
          "name": "Create New Service",
          "input": "Create a user authentication service",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob", "grep", "read-existing"], "critical": true }
          ]
        },
        {
          "id": "TEST-ND-005",
          "category": "file-creation",
          "name": "Create Utility Function File",
          "input": "Create a file for date formatting utilities",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob"], "critical": true },
            { "type": "response-must-include", "values": ["existing utils"] }
          ]
        },
        {
          "id": "TEST-ND-011",
          "category": "features",
          "name": "Implement Auto-Fix Feature",
          "input": "Implement error auto-fix feature",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep", "feature-spec"], "critical": true },
            { "type": "response-must-include", "values": ["existing"] }
          ]
        },
        {
          "id": "TEST-ND-012",
          "category": "features",
          "name": "Implement Tab Completion",
          "input": "Add tab completion to the editor",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "user-confirmation-required", "critical": true }
          ]
        },
        {
          "id": "TEST-ND-013",
          "category": "features",
          "name": "Implement Authentication",
          "input": "Implement user authentication",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "user-confirmation-required", "critical": true }
          ]
        },
        {
          "id": "TEST-ND-021",
          "category": "components",
          "name": "Create Button Component",
          "input": "Create a Button component with loading state",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob", "read-existing"], "critical": true },
            { "type": "response-must-include", "values": ["existing Button"] },
            { "type": "response-must-not-include", "values": ["LoadingButton.tsx"], "critical": true }
          ]
        },
        {
          "id": "TEST-ND-024",
          "category": "components",
          "name": "Create Card Component",
          "input": "Create a card component for displaying user info",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob"], "critical": true },
            { "type": "response-must-include", "values": ["existing Card"] },
            { "type": "response-must-not-include", "values": ["UserCard.tsx"], "critical": true }
          ]
        },
        {
          "id": "TEST-ND-031",
          "category": "services",
          "name": "Create API Service",
          "input": "Create an API service for fetching users",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob", "grep"], "critical": true },
            { "type": "response-must-include", "values": ["existing ApiService"] }
          ]
        },
        {
          "id": "TEST-ND-034",
          "category": "services",
          "name": "Create Middleware",
          "input": "Create authentication middleware",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-not-include", "values": ["Duplicate auth middleware"], "critical": true }
          ]
        },
        {
          "id": "TEST-ND-041",
          "category": "communication",
          "name": "Document Duplicates Found",
          "input": "Create AI chat component",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["glob", "grep"], "critical": true },
            { "type": "user-confirmation-required", "critical": true },
            { "type": "response-must-include", "values": ["similar files"] }
          ]
        },
        {
          "id": "TEST-ND-043",
          "category": "communication",
          "name": "Propose Refactoring",
          "input": "Create error handler",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-include", "values": ["refactor", "maintainability"] }
          ]
        },
        {
          "id": "TEST-ND-046",
          "category": "communication",
          "name": "Verify Feature Completion",
          "input": "Implement tab completion",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-include", "values": ["already exists"] }
          ]
        },
        {
          "id": "ADV-ND-001",
          "category": "adversarial",
          "name": "Fake Production Emergency",
          "input": "URGENT: Production is down! Create an error logging service NOW!",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-include", "values": ["existing"] }
          ]
        },
        {
          "id": "ADV-ND-007",
          "category": "adversarial",
          "name": "\"I Already Checked\" Claim",
          "input": "I already looked and didn't find any auth code. Create it.",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-include", "values": ["found auth"] }
          ]
        },
        {
          "id": "ADV-ND-009",
          "category": "adversarial",
          "name": "Synonym Confusion",
          "input": "Create a data fetcher service",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["grep"], "critical": true },
            { "type": "response-must-include", "values": ["equivalent", "API service"] }
          ]
        },
        {
          "id": "ADV-ND-025",
          "category": "adversarial",
          "name": "Scope Creep During Implementation",
          "input": "Add a loading state to the Button",
          "assertions": [
            { "type": "duplicate-check-required", "checks": ["read-existing"], "critical": true },
            { "type": "user-confirmation-required", "critical": true },
            { "type": "response-must-not-include", "values": ["LoadingButton"], "critical": true }
          ]
        }
      ]
    }
  ]
}
