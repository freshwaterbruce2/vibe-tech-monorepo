{
  "name": "@vibetech/workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Vibe Tech multi-project monorepo with booking platforms, web apps, and desktop applications",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.28.2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "typescript": "5.9.3",
      "better-sqlite3": "12.6.2",
      "entities": "4.5.0",
      "parse5": "7.1.2",
      "vibe-tutor>tailwindcss": "3.4.15",
      "tailwindcss": "4.1.18",
      "@modelcontextprotocol/sdk": "1.26.0",
      "form-data": "4.0.4",
      "node-forge": "1.3.2",
      "qs": "6.14.1",
      "tar": "7.5.8",
      "got": "11.8.6",
      "esbuild": "0.27.3",
      "@conventional-changelog/git-client": "2.5.1",
      "diff": "8.0.3",
      "zod": "^4.3.6"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@playwright/test",
      "@scarf/scarf",
      "@sentry/cli",
      "@swc/core",
      "bcrypt",
      "better-sqlite3",
      "bufferutil",
      "cmake-bare",
      "core-js",
      "dtrace-provider",
      "electron",
      "electron-winstaller",
      "esbuild",
      "extract-file-icon",
      "msw",
      "node-pty",
      "node-window-manager",
      "nx",
      "@prisma/engines",
      "prisma",
      "protobufjs",
      "puppeteer",
      "robotjs",
      "sharp",
      "snyk",
      "sqlite3",
      "unrs-resolver",
      "utf-8-validate",
      "workerd"
    ]
  },
  "scripts": {
    "evaluate:target": "tsx backend/openrouter-proxy/src/utils/eval.ts",
    "evaluate:token-counter": "pnpm exec tsx packages/shared-utils/src/ai/eval.ts",
    "dev": "nx run vtde:dev",
    "dev:gravity-claw": "nx run gravity-claw:dev",
    "build": "echo 'ERROR: Do not run build from workspace root. cd into a specific app first.' && exit 1",
    "build:production": "vite build --config vite.config.production.ts",
    "build:dev": "vite build --mode development",
    "lint": "nx run-many -t lint",
    "lint:biome": "biome check .",
    "lint:fix": "node --max-old-space-size=8192 ./node_modules/eslint/bin/eslint.js . --fix",
    "lint:all": "nx run-many -t lint",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "doc:cleanup": "powershell -ExecutionPolicy Bypass -File scripts\\docs-cleanup.ps1",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "format:prettier": "prettier --write .",
    "preview": "vite preview",
    "analyze": "pnpm run build:production && pnpm dlx vite-bundle-analyzer dist",
    "test": "nx run-many -t test",
    "test:e2e": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:debug": "playwright test --debug",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:coverage": "pnpm run test:unit:coverage && pnpm run crypto:coverage",
    "test:coverage:all": "nx run-many -t test:coverage",
    "coverage:report": "pnpm run test:unit:coverage && pnpm run crypto:coverage:report",
    "typecheck": "nx run-many -t typecheck",
    "typecheck:ci": "nx run-many -t typecheck --all --parallel=4",
    "typecheck:quarantine": "nx run-many -t typecheck:quarantine --projects=vibe-booking-backend --parallel=2",
    "quality": "nx run-many -t lint typecheck build",
    "quality:fix": "nx run-many -t lint:fix typecheck",
    "quality:affected": "nx affected -t lint typecheck build",
    "sync:audit": "node scripts/monorepo-sync-audit.mjs",
    "sync:audit:report": "node scripts/monorepo-sync-audit.mjs --report-only",
    "paths:check": "powershell -ExecutionPolicy Bypass -File scripts\\check-vibe-paths.ps1",
    "databases:health": "powershell -ExecutionPolicy Bypass -File scripts\\database-health.ps1 -OutputPath tmp\\database-health-report.json",
    "memory:health": "powershell -ExecutionPolicy Bypass -File scripts\\memory-health-check.ps1 -OutputPath tmp\\memory-health-report.json",
    "learning:validate": "powershell -ExecutionPolicy Bypass -File scripts\\validate-learning-system.ps1",
    "workspace:inventory": "node scripts/monorepo-sync-audit.mjs --report-only",
    "workspace:cleanup:dry": "node scripts/monorepo-sync-audit.mjs --report-only --focus=cleanup",
    "workspace:health": "powershell -ExecutionPolicy Bypass -File scripts\\workspace-health.ps1 -OutputPath tmp\\workspace-health-report.json",
    "workspace:cleanup:drift": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-stale-artifacts.ps1",
    "workspace:cleanup:drift:dry": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-stale-artifacts.ps1 -DryRun",
    "ci:sync": "pnpm run sync:audit",
    "ci:lint": "nx affected -t lint --base=origin/main --head=HEAD",
    "ci:typecheck": "nx affected -t typecheck --base=origin/main --head=HEAD",
    "ci:test": "nx affected -t test --base=origin/main --head=HEAD",
    "ci:build": "nx affected -t build --base=origin/main --head=HEAD",
    "ci:lint:all": "nx run-many -t lint --all",
    "ci:typecheck:all": "nx run-many -t typecheck --all",
    "ci:test:all": "nx run-many -t test --all",
    "ci:build:all": "nx run-many -t build --all",
    "build:all": "nx run-many -t build",
    "build:production:all": "nx run-many -t build:production",
    "test:all": "nx run-many -t test",
    "test:unit:all": "nx run-many -t test:unit",
    "lint:fix:all": "nx run-many -t lint:fix",
    "typecheck:all": "nx run-many -t typecheck",
    "graph": "nx graph",
    "affected:graph": "nx affected:graph",
    "nx:reset": "nx reset",
    "workspace:install": "pnpm install && pnpm run projects:install",
    "workspace:clean": "pnpm run clean:root && pnpm run projects:clean",
    "projects:install": "pnpm run crypto:install",
    "projects:clean": "pnpm run crypto:clean && pnpm run clean:artifacts",
    "crypto:install": "cd apps/crypto-enhanced && python -m venv .venv && .venv\\Scripts\\pip install -r requirements.txt",
    "crypto:clean": "cd apps/crypto-enhanced && rmdir /s /q .venv __pycache__ 2>nul || echo \"Clean completed\"",
    "clean:root": "rmdir /s /q node_modules .nx dist playwright-report 2>nul || echo \"Root clean completed\"",
    "clean:nx": "nx run-many -t clean",
    "clean:artifacts": "del /q *.log 2>nul && del /q fix-*.* 2>nul || echo \"Artifact clean completed\"",
    "monorepo:health": "pnpm run quality && pnpm run crypto:test",
    "crypto:test": "cd apps/crypto-enhanced && .venv\\Scripts\\python.exe run_tests.py",
    "crypto:coverage": "cd apps/crypto-enhanced && .venv\\Scripts\\python.exe -m pytest --cov=. --cov-report=term-missing --cov-report=html --cov-report=json --cov-report=xml",
    "crypto:coverage:report": "cd apps/crypto-enhanced && start coverage_html\\index.html",
    "parallel": "powershell -ExecutionPolicy Bypass -File scripts\\workspace-manager.ps1 -Action parallel",
    "parallel:dev": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group dev",
    "parallel:full-stack": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group full-stack",
    "parallel:trading": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group trading",
    "parallel:desktop": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group desktop",
    "parallel:web-apps": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group web-apps",
    "parallel:test": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group testing",
    "parallel:watch": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group dev -Watch",
    "parallel:dashboard": "powershell -ExecutionPolicy Bypass -File scripts\\Start-ParallelMonorepo.ps1 -Group dev -Dashboard",
    "parallel:status": "powershell -ExecutionPolicy Bypass -File scripts\\workspace-manager.ps1 -Action status -Parallel",
    "parallel:stop": "powershell -ExecutionPolicy Bypass -Command \"& { . .\\scripts\\workspace-manager.ps1 -Action status; Stop-ParallelEnvironment }\"",
    "release": "npx tsx scripts/release.ts",
    "release:dry-run": "npx tsx scripts/release.ts --dry-run",
    "release:first": "npx tsx scripts/release.ts --first-release",
    "release:version": "npx nx release version",
    "cleanup:pnpm": "powershell -ExecutionPolicy Bypass -File scripts\\pnpm-cleanup.ps1",
    "cleanup:pnpm:dry": "powershell -ExecutionPolicy Bypass -File scripts\\pnpm-cleanup.ps1 -DryRun",
    "cleanup": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-processes.ps1",
    "cleanup:dry": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-processes.ps1 -DryRun",
    "cleanup:all": "powershell -ExecutionPolicy Bypass -File scripts\\cleanup-processes.ps1 -All",
    "review": "node scripts/review.mjs",
    "review:all": "node scripts/review.mjs --all",
    "review:strict": "node scripts/review.mjs --strict-heuristics"
  },
  "dependencies": {
    "@floating-ui/core": "^1.7.5",
