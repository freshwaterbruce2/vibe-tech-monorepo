    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.6",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
