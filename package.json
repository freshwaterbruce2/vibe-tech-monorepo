    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "28.1.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "nx": "22.5.0",
    "nx-cloud": "19.1.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "4.1.18",
    "terser": "^5.46.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
