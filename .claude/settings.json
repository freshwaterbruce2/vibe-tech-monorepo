{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "MAX_THINKING_TOKENS": "32000",
    "BASH_DEFAULT_TIMEOUT_MS": "120000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "BASH_MAX_OUTPUT_LENGTH": "100000",
    "MCP_TIMEOUT": "60000",
    "MCP_TOOL_TIMEOUT": "60000",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "DISABLE_COST_WARNINGS": "0",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "0",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "0",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "20000",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm nx:*)",
      "Bash(npm run:*)",
      "Bash(npx nx:*)",
      "Bash(npx:*)",
      "Bash(tsx:*)",
      "Bash(jj:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git pull:*)",
      "Bash(python:*)",
      "Bash(powershell:*)",
      "Bash(node:*)",
      "Bash(sqlite3:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(test:*)",
      "Edit",
      "Write",
      "Read"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./apps/crypto-enhanced/.env)",
      "Read(./apps/crypto-enhanced/nonce_state_primary.json)",
      "Read(./apps/crypto-enhanced/nonce_state_secondary.json)",
      "Read(./apps/crypto-enhanced/config.py)",
      "Bash(rm -rf:*)",
      "Bash(format:*)",
      "Bash(diskpart:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(del:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "D:/databases",
      "D:/logs",
      "D:/logs/learning-system",
      "D:/learning-system",
      "D:/data",
      "D:/temp",
      "D:/cache",
      "D:/backups"
    ]
  },
  "model": "claude-sonnet-4-6",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [],
  "disabledMcpjsonServers": [
    "puppeteer"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/lats-pipeline-start.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/record-agent-execution.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/lats-backpropagate.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/lats-pipeline-finish.ps1"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/lats-self-critique.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/lats-skill-evolve.ps1"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/status-line.ps1"
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".nx", ".cache", "dist"],
    "sparsePaths": ["apps/", "packages/", "backend/", "tools/", ".claude/"]
  },
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "serena@claude-plugins-official": true
  }
}
