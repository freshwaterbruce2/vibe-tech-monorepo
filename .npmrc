shamefully-hoist=true
node-linker=hoisted
package-import-method=copy
public-hoist-pattern[]=*rollup*
public-hoist-pattern[]=@rollup/*
engine-strict=true
store-dir=D:\pnpm-store-v2
# Keep the hoisted linker until the React Native/Capacitor/Electron projects are
# revalidated with pnpm's default isolated linker.
minimum-release-age=1440
minimum-release-age-exclude[]=@vibetech/*
minimum-release-age-exclude[]=@nova/*
trust-policy=no-downgrade
trust-policy-ignore-after=10080
