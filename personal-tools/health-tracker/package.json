{
  "name": "@vibetech/health-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Personal four-dimension wellness tracker (physical, mental, emotional, spiritual). Local-first PWA.",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5190 --host=0.0.0.0",
    "build": "tsc -b && vite build",
    "mobile:sync": "pnpm run build && cap sync android",
    "mobile:android:debug": "pnpm run mobile:sync && cd android && gradlew.bat assembleDebug",
    "mobile:android:debug:win": "powershell -ExecutionPolicy Bypass -File scripts\\build-android-debug.ps1",
    "mobile:android:release": "pnpm run mobile:sync && cd android && gradlew.bat assembleRelease",
    "mobile:android:bundle:win": "powershell -ExecutionPolicy Bypass -File scripts\\build-android-release-bundle.ps1",
    "preview": "vite preview --host=0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
