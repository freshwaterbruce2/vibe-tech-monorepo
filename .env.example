# ============================================================
# Workspace Root .env.example -- Naming Conventions
# ============================================================
# Rules for all apps in this monorepo:
#   Frontend (Vite) vars:  VITE_* prefix  (exposed to browser)
#   Backend/server vars:   no prefix       (server-side only)
#   Database:              DATABASE_URL    (full Postgres connection string)
#   Port:                  PORT
#   OpenRouter (backend):  OPENROUTER_API_KEY
#   OpenRouter (frontend): VITE_OPENROUTER_API_KEY
#   App display strings:   VITE_APP_NAME, VITE_APP_URL
# ============================================================

# API endpoint for frontend to reach backend
VITE_API_URL=http://localhost:9001

# Production API URL (replace with deployed backend URL)
# VITE_API_URL=https://your-backend-domain.com

# Backend Service URL for deployment
VITE_BACKEND_SERVICE_URL=https://your-backend.up.railway.app

# Analytics Configuration
VITE_ANALYTICS_ID=
VITE_GTM_ID=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Security
VITE_APP_ENV=development
