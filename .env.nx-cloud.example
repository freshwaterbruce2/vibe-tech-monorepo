# Nx Cloud Configuration
# ======================
# Follow these steps to enable Nx Cloud remote caching:
#
# 1. Get your access token:
#    pnpm nx-cloud login --generate-token
#
# 2. Copy the token and add it below
#
# 3. Copy this file to .env and .env.local:
#    copy .env.nx-cloud.example .env
#    copy .env.nx-cloud.example .env.local
#
# 4. Test the connection:
#    pnpm nx run logger:build
#
# Your Nx Cloud Access Token:
NX_CLOUD_ACCESS_TOKEN=your-token-here

# Workspace ID (already configured in nx.json):
# nxCloudId: 69628705131c1b679696c8f9

# Optional: Enable distributed task execution
NX_CLOUD_DISTRIBUTED_EXECUTION=true

# Optional: Set custom cache directory
# NX_CACHE_DIRECTORY=.nx/cache

# Connect URL (if you need to re-link):
# https://cloud.nx.app/connect/WyddC9VWgY
