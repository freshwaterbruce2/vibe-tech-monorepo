{
  "mcpServers": {
    "nx-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx.cmd", "-y", "nx-mcp@latest"],
      "env": {
        "NX_WORKSPACE_ROOT": "C:/dev"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx.cmd",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/dev",
        "D:/databases",
        "D:/logs",
        "D:/learning-system",
        "D:/data"
      ]
    },
    "memory": {
      "type": "stdio",
      "command": "node",
      "args": ["C:/dev/apps/memory-mcp/dist/index.js"],
      "env": {
        "MEMORY_DB_PATH": "D:/databases/memory.db",
        "LEARNING_DB_PATH": "D:/databases/agent_learning.db"
      }
    }
  }
}
