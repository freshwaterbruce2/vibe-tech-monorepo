# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Settings (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8080

# Rate Limiting (2026 Best Practices)
# Free tier: 50 req/day, 20 req/min
# Paid tier ($10+): 1000 req/day, 20 req/min
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Logging
LOG_LEVEL=info
LOG_DIR=D:\logs\openrouter-proxy

# Usage Tracking Database
USAGE_DB_PATH=D:\databases\openrouter-usage.json

# Default Model (2026 Recommended)
DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Free Model Fallback (for development)
FREE_MODEL=mimo/mimo-v2-flash:free

# Streaming Configuration
ENABLE_STREAMING=true
STREAMING_TIMEOUT=120000

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Cost Alerts (in USD)
DAILY_COST_LIMIT=10.00
ALERT_THRESHOLD=0.75
