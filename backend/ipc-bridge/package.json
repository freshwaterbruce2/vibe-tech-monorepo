{
  "name": "ipc-bridge",
  "version": "1.0.0",
  "description": "WebSocket bridge for NOVA Agent and Vibe Code Studio communication",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --import ts-node/register src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-windows-service.ps1",
    "service:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/remove-windows-service.ps1"
  },
  "keywords": [
    "websocket",
    "ipc",
    "bridge"
  ],
  "author": "VibeTech",
  "license": "MIT",
  "dependencies": {
    "@vibetech/shared-ipc": "workspace:^1.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
